<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:paddingStart="24dp"
    android:paddingEnd="24dp">

    <!-- 상단 여백 -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="48dp" />

    <!-- 헤더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_media_previous"
            app:tint="#111111" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="게시글작성"
            android:textColor="#000000"
            android:textSize="30sp"
            android:textStyle="bold" />

        <Space
            android:layout_width="42dp"
            android:layout_height="42dp" />

    </LinearLayout>

    <!-- 스크롤 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 태그 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="태그"
                android:textColor="#111111"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinnerTag"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_write_input" />

            <!-- 지역 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="지역"
                android:textColor="#111111"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinnerRegion"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_write_input" />

            <!-- 제목 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="제목"
                android:textColor="#111111"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etTitle"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_write_input"
                android:hint="제목을 입력해 주세요"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="#111111"
                android:textColorHint="#999999"
                android:textSize="16sp" />

            <!-- 상세주소 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="상세주소"
                android:textColor="#111111"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etLocation"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_write_input"
                android:hint="상세주소를 입력해주세요"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="#111111"
                android:textColorHint="#999999"
                android:textSize="16sp" />

            <!-- 날짜 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="날짜"
                android:textColor="#111111"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etDate"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_write_input"
                android:hint="날짜를 선택해주세요"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="#111111"
                android:textColorHint="#999999"
                android:textSize="16sp"
                android:focusable="false"
                android:clickable="true" />

            <!-- 내용 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="내용"
                android:textColor="#111111"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etContent"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_write_input"
                android:gravity="top"
                android:hint="내용 입력해 주세요"
                android:padding="16dp"
                android:textColor="#111111"
                android:textColorHint="#999999"
                android:textSize="16sp" />

            <!-- 첨부파일 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="첨부파일"
                android:textColor="#111111"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- 이미지 미리보기 -->
                <ImageView
                    android:id="@+id/imgPreview"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/chef_illustration" />

                <!-- 파일 정보 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <!-- 파일명 -->
                    <TextView
                        android:id="@+id/tvFileName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="선택된 이미지 없음"
                        android:textColor="#111111"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <!-- 용량 -->
                    <TextView
                        android:id="@+id/tvFileSize"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text=""
                        android:textColor="#777777"
                        android:textSize="13sp" />

                </LinearLayout>

                <!-- 이미지 추가 버튼 -->
                <Button
                    android:id="@+id/btnAddImage"
                    android:layout_width="140dp"
                    android:layout_height="52dp"
                    android:backgroundTint="#FFFFFF"
                    android:text="+ 이미지 추가"
                    android:textAllCaps="false"
                    android:textColor="#111111"
                    android:textSize="15sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- 하단 여백 -->
            <Space
                android:layout_width="match_parent"
                android:layout_height="20dp" />

        </LinearLayout>

    </ScrollView>

    <!-- 하단 버튼 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="62dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="8dp">

        <!-- 등록 -->
        <Button
            android:id="@+id/btnUpload"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:backgroundTint="#FF6A1A"
            android:text="등록하기"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- 취소 -->
        <Button
            android:id="@+id/btnCancel"
            android:layout_width="110dp"
            android:layout_height="52dp"
            android:layout_marginStart="12dp"
            android:backgroundTint="#FFFFFF"
            android:text="취소"
            android:textAllCaps="false"
            android:textColor="#D66A2A"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>