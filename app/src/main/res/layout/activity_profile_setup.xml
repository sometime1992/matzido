<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF0F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="40dp">

        <!-- 상단 아이콘 + 타이틀 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="36dp">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/matimg"
                android:contentDescription="앱 아이콘"
                android:layout_marginBottom="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="프로필 설정"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#E84A8A"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="맛남의 광장에서 사용할 정보를 입력해주세요"
                android:textSize="13sp"
                android:textColor="#B07090"
                android:gravity="center" />
        </LinearLayout>

        <!-- ───────────────────────────── -->
        <!-- 섹션 1: 닉네임 (활성화) -->
        <!-- ───────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="닉네임"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#E84A8A"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etnickname"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input_pink"
            android:hint="닉네임을 입력하세요 (2~10자)"
            android:textColorHint="#D0A0B8"
            android:inputType="text"
            android:maxLength="10"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="#333333"
            android:textSize="15sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvNicknameCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginEnd="4dp"
            android:text="0 / 10"
            android:textSize="11sp"
            android:textColor="#C0A0B0"
            android:layout_marginBottom="28dp" />

        <!-- ───────────────────────────── -->
        <!-- 섹션 2 & 3: 연령대 및 지역 (협의 전까지 숨김 처리) -->
        <!-- ───────────────────────────── -->
        <!-- 나중에 다시 쓰려면 아래 LinearLayout의 visibility를 "visible"로 바꾸세요 -->
        <LinearLayout
            android:id="@+id/layoutHiddenSections"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"> <!-- 🚀 여기를 gone으로 설정했습니다 -->

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F5D0E0"
                android:layout_marginBottom="28dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="연령대"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#E84A8A"
                android:layout_marginBottom="4dp" />

            <!-- (이하 연령대/지역 버튼 그리드들 생략 - 원본 코드는 유지하되 부모 레이아웃이 gone이라 안 보임) -->
        </LinearLayout>

        <!-- ───────────────────────────── -->
        <!-- 시작하기 버튼 (위로 올림) -->
        <!-- ───────────────────────────── -->
        <LinearLayout
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/bg_btn_start"
            android:orientation="horizontal"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginTop="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="맛남의 광장 시작하기"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="나중에 설정에서 변경할 수 있어요"
            android:textSize="11sp"
            android:textColor="#C0A0B0" />

    </LinearLayout>
</ScrollView>