<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- z-index 1: 지도 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.kakao.vectormap.MapView
            android:id="@+id/map_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </FrameLayout>

    <!-- z-index 2: 바텀 시트 (elevation 16dp) -->
    <!-- android:layout_height="500dp" 높이조정 -->
    <!-- app:behavior_peekHeight="150dp" 시작위치 조정 -->
    <LinearLayout
        android:id="@+id/bottom_sheet"
        android:layout_width="match_parent"
        android:layout_height="500dp"
        android:background="#FFFFFF"
        android:orientation="vertical"
        android:elevation="16dp"
        app:behavior_hideable="false"
        app:behavior_peekHeight="150dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:background="#E0E0E0" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="80dp">

            <LinearLayout
                android:id="@+id/ll_search_result_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </androidx.core.widget.NestedScrollView>

    </LinearLayout>

    <!-- z-index 2.5: 상세페이지 (바텀시트 위에 띄움, elevation 18dp) -->
    <LinearLayout
        android:id="@+id/detail_page"
        android:layout_width="match_parent"
        android:layout_height="500dp"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        android:orientation="vertical"
        android:elevation="18dp"
        android:visibility="gone">

        <!-- 상단: 제목 + 닫기 버튼 -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <TextView
                android:id="@+id/tv_detail_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#222222" />

            <Button
                android:id="@+id/btn_detail_close"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="✕"
                android:textSize="16sp"
                android:minWidth="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />

        </RelativeLayout>

        <!-- 구분선 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE" />

        <!-- 탭 영역 (홈/메뉴/사진/리뷰1/리뷰2) -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:tabMode="fixed">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="홈" />
            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="메뉴" />
            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="사진" />
            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="리뷰1" />
            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="리뷰2" />
        </com.google.android.material.tabs.TabLayout>

        <!-- 탭별 콘텐츠 영역 (자식 5개가 visibility 토글로 전환) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/tab_home"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="visible">

                <!-- 영업여부 + 영업시간 (예: 영업 중 · 22:00 까지) -->
                <TextView
                    android:id="@+id/tv_home_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:textSize="16sp"
                    android:textColor="#333333" />

                <!-- 주소 -->
                <TextView
                    android:id="@+id/tv_home_address"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:textSize="14sp"
                    android:textColor="#666666" />

                <!-- 전화번호 -->
                <TextView
                    android:id="@+id/tv_home_phone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="#666666" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/tab_menu"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- 메뉴 없을 때 placeholder -->
                        <TextView
                            android:id="@+id/tv_menu_empty"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:padding="32dp"
                            android:text="메뉴정보없음"
                            android:textSize="16sp"
                            android:textColor="#888888"
                            android:visibility="gone" />

                        <LinearLayout
                            android:id="@+id/ll_menu_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />

                    </LinearLayout>
                </ScrollView>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tab_photo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- 사진 없을 때 placeholder -->
                        <TextView
                            android:id="@+id/tv_photo_empty"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:padding="32dp"
                            android:text="사진 없음"
                            android:textSize="16sp"
                            android:textColor="#888888"
                            android:visibility="gone" />

                        <!-- 3열 그리드로 사진 배치 -->
                        <GridLayout
                            android:id="@+id/gl_photo_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:columnCount="3" />

                        <!-- 더보기 버튼 (12개씩 추가) -->
                        <Button
                            android:id="@+id/btn_load_more_photo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="8dp"
                            android:text="더보기"
                            android:visibility="gone" />

                    </LinearLayout>
                </ScrollView>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/tab_review1"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- 리뷰 없을 때 placeholder -->
                        <TextView
                            android:id="@+id/tv_review_empty"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:padding="32dp"
                            android:text="리뷰 없음"
                            android:textSize="16sp"
                            android:textColor="#888888"
                            android:visibility="gone" />

                        <LinearLayout
                            android:id="@+id/ll_review_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />

                    </LinearLayout>
                </ScrollView>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tab_review2"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="리뷰2 탭 내용"
                    android:textSize="24sp"
                    android:textColor="#333333" />
            </LinearLayout>
        </FrameLayout>

    </LinearLayout>

    <!-- z-index 2.7: 상세페이지 로딩 뷰 (detail_page 위에 덮어 표시, elevation 19dp) -->
    <FrameLayout
        android:id="@+id/view_detail_loading"
        android:layout_width="match_parent"
        android:layout_height="500dp"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        android:elevation="19dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="로딩중"
            android:textSize="18sp"
            android:textColor="#333333" />

    </FrameLayout>

    <!-- z-index 3: 전체 화면 오버레이 (바텀시트 포함 화면 전체를 덮음, elevation 20dp) -->
    <LinearLayout
        android:id="@+id/overlay_suggestion"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF"
        android:orientation="vertical"
        android:elevation="20dp"
        android:visibility="gone">

        <!-- 검색창 높이만큼 공간 확보 (검색창과 리스트가 겹치지 않도록) -->
        <View
            android:layout_width="match_parent"
            android:layout_height="80dp" />

        <!-- 검색창과 리스트 사이 구분선 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:id="@+id/ll_suggestion_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </ScrollView>
    </LinearLayout>

    <!-- z-index 4: 검색창 (항상 최상단, elevation 24dp, 배경 없음 → 그림자 없음) -->
    <LinearLayout
        android:id="@+id/layout_search_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_margin="16dp"
        android:orientation="vertical"
        android:elevation="24dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp"
                android:gravity="center_vertical">

                <Button
                    android:id="@+id/btn_toggle_suggestion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▼"
                    android:textSize="12sp"
                    android:minWidth="0dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp" />

                <EditText
                    android:id="@+id/et_search"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="장소를 검색하세요"
                    android:padding="8dp"
                    android:singleLine="true"
                    android:imeOptions="actionSearch"/>

                <Button
                    android:id="@+id/btn_search"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="검색" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- z-index 5: 로딩 뷰 (최상단, elevation 28dp) -->
    <FrameLayout
        android:id="@+id/view_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF"
        android:elevation="28dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="로딩중"
            android:textSize="18sp"
            android:textColor="#333333" />

    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
